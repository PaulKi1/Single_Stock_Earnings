# =============================================================================
# Secrets — never commit your real Databento key
# =============================================================================
.env
.env.local
.env.*.local
# (..env.example is intentionally NOT ignored — it is a safe template to commit.)

# =============================================================================
# Generated pipeline data (regenerated by running the pipeline; can be large)
# The runner and each module create these folders automatically with
# mkdir(parents=True, exist_ok=True), so they do not need to live in the repo.
# =============================================================================
data/

# Databento raw request cache / stray DBN files (normally inside data/, but
# listed explicitly in case the cache is ever relocated)
*.dbn
*.dbn.zst

# Optional dashboard PNG export, if you ever enable it
dashboard_preview.png

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# =============================================================================
# Virtual environments
# =============================================================================
.venv/
venv/
env/
ENV/

# =============================================================================
# PyCharm / JetBrains IDE files
# =============================================================================
.idea/

# =============================================================================
# OS cruft
# =============================================================================
.DS_Store
Thumbs.db
